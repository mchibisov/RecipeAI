# Порт, на котором запускается локальный сервер.
PORT=8000

# Подключение к PostgreSQL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recipes_app

# Ключ Mistral для AI-функций.
MISTRAL_API_KEY=your_mistral_api_key

# Модель Mistral. Можно оставить значение по умолчанию.
MISTRAL_MODEL=mistral-small-latest

# Для учебного проекта с TheMealDB можно использовать тестовый ключ 1.
THEMEALDB_API_KEY=1

# Обычно это не нужно.
# Включайте только если Python в вашей системе ругается на SSL-сертификаты внешних API.
# ALLOW_INSECURE_SSL=1
